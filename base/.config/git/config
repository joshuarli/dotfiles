[user]
    name = Joshua Li
    email = joshuarli98@gmail.com

[url "git@github.com:"]
    insteadOf = https://github.com/

[core]
    ignorecase = true
    pager = delta

    # commit-graph for fast traversal
    commitGraph = true

    # cache untracked dir mtimes to avoid rescanning unchanged dirs
    untrackedCache = true

    # use built-in filesystem watcher so git knows what changed without full scan
    fsmonitor = true

    # parallel index stat() calls
    preloadIndex = true

    # multi-pack-index for faster object lookup across packs
    multiPackIndex = true

[alias]
    amend = commit --amend -v
    b = blame -c --date=short
    c = checkout
    d = diff
    dc = diff --cached
    s = show
    l = log
    unstage = reset --

[interactive]
    diffFilter = delta --color-only

[push]
    default = current

[branch]
    autoSetupMerge = always

[pull]
    rebase = true

[rebase]
    autoStash = true

[diff]
    algorithm = histogram

[merge]
    conflictStyle = zdiff3

[rerere]
    enabled = true

[transfer]
    fsckObjects = true

[delta]
    features = line-numbers decorations
    syntax-theme = none
    plus-style = green
    plus-emph-style = green bold
    minus-style = red
    minus-emph-style = red bold
    line-numbers-left-format  = {nm:^4}
    line-numbers-right-format = {np:^4}
    navigate = true  # use n and N to move between diff sections

[delta "decorations"]
    file-style = magenta bold
    commit-decoration-style = none
    file-decoration-style = white box
    hunk-header-style = none
    hunk-header-decoration-style = white ul

[gc]
    writeCommitGraph = true

[fetch]
    writeCommitGraph = true
    parallel = 0

[commitGraph]
    readChangedPaths = true

[feature]
    manyFiles = true

[index]
    version = 4

[pack]
    threads = 0
    writeBitmapHashCache = true

[repack]
    writeBitmaps = true

[checkout]
    workers = 0

[protocol]
    version = 2
